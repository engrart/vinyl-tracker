# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vinyltracker

# ── Auth — works for Clerk or Auth0 ─────────────────────────────────────────
# Clerk:  https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
# Auth0:  https://<your-domain>.auth0.com/.well-known/jwks.json
JWKS_URI=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json

# Clerk:  leave blank (no audience enforced by default)
# Auth0:  your API identifier, e.g. https://api.vinyltracker.app
JWT_AUDIENCE=

# Clerk:  https://your-clerk-frontend-api.clerk.accounts.dev
# Auth0:  https://your-domain.auth0.com/
JWT_ISSUER=https://your-clerk-frontend-api.clerk.accounts.dev

# ── Storage — Cloudflare R2 (S3-compatible) or AWS S3 ───────────────────────
# R2 endpoint:  https://<account_id>.r2.cloudflarestorage.com
# AWS S3:       leave blank (SDK uses default regional endpoint)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=vinyl-tracker
# Public base URL for stored objects (R2 custom domain or S3 bucket URL)
S3_PUBLIC_URL_BASE=https://assets.yourdomain.com

# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
# Required by MusicBrainz User-Agent policy
CONTACT_EMAIL=you@yourdomain.com
